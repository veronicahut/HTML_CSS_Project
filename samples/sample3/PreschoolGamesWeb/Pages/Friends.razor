@page "/friends"
@using PreschoolGames
@inject HttpClient Http

<PageTitle>Friends Game</PageTitle>

<div class="game-container" style="background-color: @gameColor; padding: 30px; border-radius: 15px; text-align: center; max-width: 600px; margin: auto; min-height: 400px;">
    <h1>Friends Game 🤝</h1>
    <p class="instructions">Look at the scenario and pick the best choice!</p>

    <div class="status-box" style="margin: 20px 0; font-size: 1.3rem; font-weight: bold; color: #2c3e50;">
        @statusMessage
    </div>

    @if (gameStarted)
    {
        <div class="card scenario-card" style="padding: 20px; border-radius: 10px; border: none; background: white; margin-bottom: 25px; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
            <h3 style="color: #2e86de;">Scenario:</h3>
            <p style="font-size: 1.25rem;">@GetQuestionText(currentQuestionId)</p>
        </div>

        <div class="choices-container" style="display: flex; flex-direction: column; gap: 15px; max-width: 400px; margin: 0 auto 25px auto;">
            @for (int i = 0; i < currentChoices.Length; i++)
            {
                int choiceId = currentChoices[i];
                <button class="btn btn-outline-primary btn-lg" 
                        style="padding: 15px; font-size: 1.1rem; border-width: 2px; font-weight: 500; text-align: left;"
                        @onclick="() => HandleAnswerSelected(choiceId)">
                    @GetAnswerText(choiceId)
                </button>
            }
        </div>
    }
    else
    {
        @if (hasAnswered)
        {
            <div class="response-display" style="font-size: 4rem; margin-bottom: 20px;">
                @responseEmoji
            </div>
        }

        <button class="btn btn-success btn-lg" @onclick="LoadNextQuestion" style="font-weight: bold; padding: 12px 40px; font-size: 1.3rem; box-shadow: 0 4px 10px rgba(0,0,0,0.15);">
            @(hasAnswered ? "Play Again! ➡️" : "Start Game ▶️")
        </button>
    }
</div>

@code {
    private FriendsGame game = new FriendsGame(1);
    private string gameColor = "white";
    private string statusMessage = "Are you ready to practice being a great friend?";
    private string responseEmoji = "";

    private int currentQuestionId;
    private int currentAnswerId;
    
    // FIXED: Expanded array bounds to accept 3 choices
    private int[] currentChoices = new int[3]; 
    
    private bool gameStarted = false;
    private bool hasAnswered = false;

    protected override void OnInitialized()
    {
        gameColor = game.Image(1);
    }

    private void LoadNextQuestion()
    {
        hasAnswered = false;
        gameStarted = true;
        statusMessage = "What is the kindest thing to do?";

        currentQuestionId = game.GetQuestion();
        currentAnswerId = game.GetAnswer(currentQuestionId);
        currentChoices = game.GetChoices(currentAnswerId);
        
        StateHasChanged();
    }

    private void HandleAnswerSelected(int selectedChoiceId)
    {
        gameStarted = false;
        hasAnswered = true;

        bool isCorrect = game.CheckAnswer(currentAnswerId, selectedChoiceId);
        int responseId = game.DisplayResponse(isCorrect);

        if (isCorrect)
        {
            statusMessage = "🎉 Excellent! You made a wonderful choice!";
            responseEmoji = GetRewardEmoji(responseId);
        }
        else
        {
            if(currentAnswerId % 2 != 0 && selectedChoiceId % 2 != 0)
            {
                statusMessage = ":) Nice thought.";
                responseEmoji = "💡";
            }
            else 
            {
                statusMessage = "😥 Let's try to make a nicer friend choice next time.";
                responseEmoji = "💡";
            }            
        }
    }

    private string GetQuestionText(int id) => id switch
    {
        1 => "Look! A boy is helping someone up.",
        2 => "Oh no, a kid is being a bully.",
        3 => "Look how nicely these kids are playing together!",
        4 => "Two kids are fighting over a stuffed toy bear.",
        5 => "Look at the kids running happily together!",
        6 => "Stop! Those kids are kicking each other.",
        7 => "These friends are done playing with blocks.",
        8 => "This man is talking way too loud inside.",
        9 => "Look at these silly kids making funny joke faces!",
        10 => "Oh no, a boy accidentally breaks a girl's toy.",
        11 => "Oops! A kid accidentally spills their milk.", 
        12 => "Hey! Those boys are pulling a girl's hair.",
        13 => "Fun! The kids are playing in a giant ball pit.",
        14 => "Oh no, a bully is kicking over a tower of blocks.",
        15 => "Look at the teamwork! Kids building blocks together.",
        16 => "Stop! Those kids are yelling at each other.",
        17 => "These friends are finished playing with the sandbox toys.",
        18 => "That boy is yelling in the library.",
        19 => "Look at those great friends sharing their electronics.",
        20 => "Those girls are fighting about cleaning up their toys.",
        _ => "Look at how nice your friends are playing!"
    };

    private string GetAnswerText(int id) => id switch
    {
        1 => "🌟 Go and ask them if you can help!",
        2 => "🛑 Ignore them, look away, and play somewhere else.",
        3 => "🌟 Ask an adult for help!",
        4 => "🛑 Laugh at them or take the toy away.",
        5 => "🌟 Ask them if you can play with them!",
        6 => "🛑 Ignore them, look away, and hide somewhere.",
        7 => "🌟 Ask them if they want to play tag instead!",
        8 => "🛑 Laugh at them or kick the ball away.",
        9 => "🌟 Go and ask them if you can join!",
        10 => "🛑 Yell at them and run away.",
        11 => "🌟 Go to them and ask them if they want to do a puzzle instead!",
        12 => "🛑 Ignore them and make faces behind their backs.",
        13 => "🌟 Help them pick them up together so it gets cleaned up fast!",
        14 => "🛑 Make mean faces at them.",
        15 => "🌟 Ask politely if he can speak quieter!",
        16 => "🛑 Ignore them and hide somewhere.",
        17 => "🌟 Ask if you can join the game!",
        18 => "🛑 Laugh at them or kick the ball away.",
        19 => "🌟 Help them clean up so everyone can play a new game!",
        20 => "🛑 Scream at them and kick toys.",
        _ => "👉 Share your toys and be polite."
    };

    private string GetRewardEmoji(int responseCode) => responseCode switch
    {
        2 => "🎈🌟🎈",
        3 => "🏆🏆🏆",
        4 => "🥇✨🥇",
        5 => "🚀🦄🚀",
        6 => "🎨👾🎨",
        7 => "🍕🎂🍕",
        _ => "⭐🌈⭐"
    };
}